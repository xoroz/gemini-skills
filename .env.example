# =============================================================================
# Review Site Factory — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# System environment variables always take precedence over .env.
#
#   cp .env.example .env
#   nano .env
# =============================================================================


# -----------------------------------------------------------------------------
# API KEYS  (at least one required for image generation)
# -----------------------------------------------------------------------------

# Primary: Google AI Studio key (free tier available)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-google-ai-studio-key

# Fallback: OpenRouter key (uses google/gemini-2.5-flash-image via OpenRouter)
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key


# -----------------------------------------------------------------------------
# SERVER (FastAPI / uvicorn)
# -----------------------------------------------------------------------------

# Port the FastAPI API listens on
# Default: 8000
PORT=8000


# -----------------------------------------------------------------------------
# REMOTE_SITE_URL  ★ key setting for remote/production deployments ★
# -----------------------------------------------------------------------------
# The public base URL where nginx (or any web server) serves the generated sites.
# This is SEPARATE from the FastAPI port above.
#
# Pattern:  http://<host>  →  sites accessible at http://<host>/<slug>/index.html
#
# Examples:
#   REMOTE_SITE_URL=http://192.168.0.114          # nginx on port 80 (LAN)
#   REMOTE_SITE_URL=https://sites.example.com     # production domain
#   REMOTE_SITE_URL=http://192.168.0.114/sites    # if sites live under /sites/
#
# When set:
#   • main.py  returns site_url in /generate-site response immediately
#   • create.sh prints the full public URL in the build summary
#   • test-all.py uses this root to validate the live site (--remote mode)
#
# When NOT set:
#   • Everything still works — only local file:// paths are shown
#
REMOTE_SITE_URL=http://192.168.0.114


# -----------------------------------------------------------------------------
# BUILD BEHAVIOUR
# -----------------------------------------------------------------------------

# Image generation mode
#   PROD   = high quality (default: google/gemini-3.1-flash-image-preview)
#   DEV    = fast/cheap   (default: black-forest-labs/flux.2-klein-4b)
#   MOCKUP = no API calls, uses placeholder images from .skel/
MODE=DEV

# Override AI models per mode (optional — sensible defaults per MODE)
# AI_MODEL_IMG=google/gemini-3.1-flash-image-preview
# AI_MODEL_TEXT=gemini-2.5-flash
# AI_COST_IMG=0.038

# Site language: it (Italian, default) | en (English)
# Controls both generated site content AND the Google Maps search language (hl= param)
# e.g. SITE_LANG=en → maps URL: ...?hl=en  and generated HTML in English
SITE_LANG=it

# Path to the Short ID registry JSON file (relative to project root).
# Use separate files to isolate DEV test IDs from production IDs:
#   Production (default, leave unset): sites/site-id.json
#   DEV / test builds:                 sites/site-id-dev.json
# When not set, defaults to sites/site-id.json
# SITE_ID_REGISTRY=sites/site-id-dev.json


# -----------------------------------------------------------------------------
# SECURITY & CORS
# -----------------------------------------------------------------------------

# Set a static Bearer token to protect the API endpoints
# e.g. run: openssl rand -hex 32
# If left blank, requests will be accepted without a token
API_TOKEN=

# Comma-separated list of allowed Frontend domains for CORS
# Leave empty or set to * to allow all origins
ALLOWED_ORIGINS=http://localhost:3000,https://my-frontend.com


# Set timeout (in seconds) for Google Maps Scraper (Playwright)
SCRAPE_TIMEOUT=240


# -----------------------------------------------------------------------------
# SMTP — outgoing email  (used by assets/bin/send_mail.py)
# -----------------------------------------------------------------------------
# OVH shared hosting SMTP — adjust host/port for other providers:
#   Gmail:      smtp.gmail.com  / 587  (use an App Password)
#   Aruba:      smtps.aruba.it  / 465  (use SSL instead of STARTTLS)
#   Sendgrid:   smtp.sendgrid.net / 587

SMTP_HOST=ssl0.ovh.net
SMTP_PORT=587
SMTP_USER=[email protected]
SMTP_PASS=your-mailbox-password


# -----------------------------------------------------------------------------
# OPENAPI — Ufficio Postale  (physical letter sending via Posta Ordinaria)
# -----------------------------------------------------------------------------
# Get your token at: https://console.openapi.com/oauth
# API docs: https://console.openapi.com/apis/ufficiopostale/documentation

OPENAPI_POST=your-openapi-post-token

# Sender address (printed on the letter envelope)
LETTER_SENDER_NAME=TexNGo
LETTER_SENDER_COGNOME=AI Agency
LETTER_SENDER_DUG=Via
LETTER_SENDER_ADDRESS=Your Street Name
LETTER_SENDER_CIVICO=1
LETTER_SENDER_CAP=00100
LETTER_SENDER_COMUNE=Roma
LETTER_SENDER_PROVINCIA=RM
LETTER_SENDER_EMAIL=[email protected]
